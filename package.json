{
  "name": "max-wedding",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/server.ts",
    "build": "next build && node scripts/tsc-server-build.mjs",
    "start": "cross-env NODE_ENV=production node server/server.js",
    "dev-prod": "cross-env DB='LOCAL' NODE_ENV=production tsx server/server.ts",
    "start:server:prod": "cross-env DB='HOST' NODE_ENV=production node server/server.js",
    "start:server:docker:dev": "cross-env DB='LOCAL' IS_DOCKER='TRUE' NODE_ENV=production node server/server.js",
    "lint": "eslint \"src\" \"server\" \"shared\"",
    "migration:create": "typeorm migration:create",
    "migration:create:name": "tsx server/db/migrations/helpers/create-migration.helper.ts",
    "migration:run": "cross-env NODE_ENV=development tsx ./node_modules/typeorm/cli.js migration:run -d server/db/data-source.ts",
    "migration:run:prod": "cross-env NODE_ENV=production node ./node_modules/typeorm/cli.js migration:run -d server/db/data-source.js",
    "migration:revert": "cross-env NODE_ENV=development tsx ./node_modules/typeorm/cli.js migration:revert -d server/db/data-source.ts"
  },
  "dependencies": {
    "@ant-design/icons": "6.1.1",
    "@ant-design/nextjs-registry": "1.3.0",
    "antd": "6.3.6",
    "axios": "1.13.2",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "exceljs": "4.4.0",
    "express": "4.22.1",
    "https-proxy-agent": "7.0.6",
    "i18next": "25.7.3",
    "lodash": "4.17.21",
    "moment-timezone": "0.6.0",
    "next": "16.2.4",
    "pg": "8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "16.5.0",
    "reflect-metadata": "0.2.2",
    "telegraf": "4.16.3",
    "typeorm": "0.3.28",
    "typescript-ioc": "3.2.2",
    "winston": "3.19.0",
    "winston-daily-rotate-file": "5.0.0",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.3",
    "@eslint/js": "9.39.1",
    "@next/eslint-plugin-next": "16.2.4",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@types/express": "4.17.25",
    "@types/lodash": "4.17.23",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.48.1",
    "@typescript-eslint/parser": "8.48.1",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.4",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "16.5.0",
    "tsc-alias": "1.8.16",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
